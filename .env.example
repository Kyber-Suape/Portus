# Porta publicada pelo Docker no host — em produção (VPS), é a porta que você abre no
# firewall/proxy. O compose repassa esse valor para dentro do container como PORT.
FRONTEND_PORT=3000

# URL pública da aplicação (usada em metadados e links absolutos)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome exibido da aplicação
NEXT_PUBLIC_APP_NAME="Portus — Portus RDO"

# Indicadores, pendências, RDOs e atividades do dashboard ainda não têm endpoint na
# API — continuam usando os mocks de `src/data` até essas rotas existirem.
NEXT_PUBLIC_USE_MOCK_DATA=true

# Base URL da API (Portus-api) consumida por auth/organizations/users. É embutida no
# bundle do cliente em tempo de build — ao mudar este valor em produção, é preciso
# reconstruir a imagem (`docker compose up -d --build`), não basta reiniciar o container.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
